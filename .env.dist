# Copy to .env and adjust for your machine.

HF_HOME=.models/huggingface

# Optional: isolate the app to one physical GPU. PCI bus ordering makes
# CUDA_VISIBLE_DEVICES match nvidia-smi indexes. If this is set to the physical
# RTX 5060 index, use logical device index 0 for model settings below.
# CUDA_DEVICE_ORDER=PCI_BUS_ID
# CUDA_VISIBLE_DEVICES=1

# Optional after running scripts/download-models.sh successfully. These keep
# normal app startup from contacting Hugging Face.
# HF_HUB_OFFLINE=1
# TRANSFORMERS_OFFLINE=1

# Leave false for scripts/download-models.sh so it can fetch missing models
# even when runtime Hugging Face offline flags are enabled above.
TRANSLATOR_DOWNLOAD_OFFLINE=false

TRANSLATOR_WINDOW_TITLE="Live Subtitles"
TRANSLATOR_PLACEHOLDER_TEXT="Waiting for audio..."
TRANSLATOR_WIDTH=960
TRANSLATOR_HEIGHT=420
TRANSLATOR_OPACITY=0.9
TRANSLATOR_ALWAYS_ON_TOP=true

# Leave empty to use the default sink monitor.
TRANSLATOR_AUDIO_SOURCE=
TRANSLATOR_AUDIO_SAMPLE_RATE=16000
TRANSLATOR_AUDIO_CHUNK_FRAMES=1600
TRANSLATOR_AUDIO_DETECTION_THRESHOLD=0.01

TRANSLATOR_SPEECH_START_MS=300
TRANSLATOR_SPEECH_END_MS=800
TRANSLATOR_SPEECH_MAX_MS=10000
TRANSLATOR_SPEECH_OVERLAP_MS=1000

# 0 is least aggressive, 3 is most aggressive.
TRANSLATOR_VAD_AGGRESSIVENESS=2
TRANSLATOR_VAD_FRAME_MS=30
TRANSLATOR_VAD_SPEECH_RATIO=0.5

# Uncomment to write debug WAV chunks.
# TRANSLATOR_DEBUG_AUDIO_DIR=debug/audio

# Uncomment to append transcript metadata and text.
# TRANSLATOR_DEBUG_TRANSCRIPT_PATH=debug/transcript.txt

TRANSLATOR_TRANSCRIPTION_ENABLED=true

# setup.sh and scripts/download-models.sh block until this model is downloaded
# and loadable with the configured device settings.
TRANSLATOR_WHISPER_MODEL=large-v3
TRANSLATOR_WHISPER_DEVICE=cuda

# Set this to the CUDA index for the dedicated transcription GPU.
TRANSLATOR_WHISPER_DEVICE_INDEX=0

TRANSLATOR_WHISPER_COMPUTE_TYPE=float16

# Leave empty for Whisper language auto-detection.
TRANSLATOR_WHISPER_LANGUAGE=
TRANSLATOR_WHISPER_TASK=transcribe
TRANSLATOR_WHISPER_BEAM_SIZE=5

TRANSLATOR_TRANSLATION_ENABLED=false
TRANSLATOR_TRANSLATION_MODEL=facebook/nllb-200-distilled-600M
TRANSLATOR_TRANSLATION_DEVICE=cpu
TRANSLATOR_TRANSLATION_DEVICE_INDEX=0
TRANSLATOR_TRANSLATION_COMPUTE_DTYPE=float32
TRANSLATOR_TRANSLATION_TARGET_LANGUAGE=eng_Latn

# original, translation, or both
TRANSLATOR_TRANSLATION_DISPLAY_MODE=both
TRANSLATOR_TRANSLATION_MAX_LENGTH=512
