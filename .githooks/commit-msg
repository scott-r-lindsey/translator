#!/usr/bin/env sh
set -eu

commit_msg_file="$1"
first_line="$(sed -n '1p' "$commit_msg_file")"

conventional_pattern='^(build|chore|ci|docs|feat|fix|perf|refactor|revert|style|test)(\([A-Za-z0-9._/-]+\))?!?: .+'

case "$first_line" in
  Merge\ *|Revert\ *|fixup!\ *|squash!\ *)
    exit 0
    ;;
esac

if printf '%s\n' "$first_line" | grep -Eq "$conventional_pattern"; then
  exit 0
fi

cat >&2 <<'EOF'
Invalid commit message.

Use Conventional Commits:
  feat: add live subtitle shell
  fix(audio): handle empty chunks
  chore!: drop unsupported Python version

Allowed types:
  build, chore, ci, docs, feat, fix, perf, refactor, revert, style, test
EOF

exit 1
